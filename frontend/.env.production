# Production build config (Vite reads this during `npm run build`).
# Baked into the bundle so every deploy — Vercel Git or CLI — targets the live
# backend rather than the localhost dev default. The API key is the public demo
# key (also in render.yaml: BACKEND_API_KEY), safe to commit for this portfolio demo.
VITE_API_URL=https://complianceagent-backend.onrender.com
VITE_API_KEY=compliance-demo-2026
