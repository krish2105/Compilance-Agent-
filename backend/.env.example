# ------------------------------------------------------------------------------
# ComplianceAgent backend configuration.
# Copy to `.env` (cp .env.example .env). The defaults below run the FULL system
# at $0 with NO API keys via the deterministic "offline" LLM provider.
# ------------------------------------------------------------------------------

# App
ENVIRONMENT=development

# --- Auth ---
# Shared secret (demo/legacy lane) required in the X-API-Key header. The real auth
# lane is JWT login (roles: analyst/mlro/admin) — see /api/auth/login.
BACKEND_API_KEY=dev-local-key
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRE_HOURS=12

# --- Operational store (users, case assignments) ---
# Postgres-ready: set a DATABASE_URL (e.g. a free Neon/Supabase instance) for real
# persistence; leave blank to use a local SQLite file ($0). DuckDB stays the
# analytical engine for transaction data regardless.
# DATABASE_URL=postgresql://user:pass@host/db
DATABASE_URL=

# --- LLM provider strategy ---
# offline = deterministic, no network, no keys, $0 (default — great for the demo/CI).
# gemini  = Google AI Studio (free tier)  -> set GEMINI_API_KEY.
# groq    = Groq Llama 3.3 70B (free tier) -> set GROQ_API_KEY.
# With fallback enabled, a failure on the primary online provider fails over to the
# other online provider and finally to the deterministic offline draft.
LLM_PROVIDER=offline
LLM_ENABLE_FALLBACK=true

# Google Gemini (primary online provider). Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (failover online provider). Get a free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_LIGHT=llama-3.1-8b-instant

# --- Hallucination guardrail: Verifier NLI entailment (HF free Inference API) ---
# A free HuggingFace read token activates an independent natural-language-inference
# check — every LLM-introduced statement must be entailed by the evidence, else the
# Verifier flags it and re-drafts deterministically. Absent a token, it no-ops and
# the deterministic guardrails (claims/citations/figures) still stand ($0, offline).
# Get a free token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=
VERIFIER_ENTAILMENT=true
HF_NLI_MODEL=MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli
ENTAILMENT_THRESHOLD=0.5
ENTAILMENT_TIMEOUT=45
ENTAILMENT_MAX_CHECKS=8

# --- Abstention: confidence-gated "escalate to human, insufficient evidence" ---
# Below this typology confidence (and not a hard sanctions escalation), or if the
# Verifier could not confirm the content, the case is flagged for escalation rather
# than presenting a confident narrative.
ABSTAIN_CONFIDENCE=0.30
ABSTAIN_ON_VERIFIER_FAIL=true

# --- Entity enrichment: GLEIF LEI lookup (real, free, no key) ---
# Best-effort legal-entity verification for organisation counterparties. Off by
# default so the demo stays fast on synthetic names; a real deployment turns it on.
ENTITY_ENRICHMENT=false
GLEIF_TIMEOUT=8

# --- Constrained decoding (lower LLM variance → fewer hallucinations) ---
# The narrator only polishes an evidence-grounded draft, so decode near-
# deterministically. Groq honours all four; Gemini honours temperature + top_p.
LLM_TEMPERATURE=0.0
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.3
LLM_SEED=42

# Cheaper model tier used by the model router for lightweight/classify tasks.
GEMINI_MODEL_LIGHT=gemini-2.5-flash-lite

# --- Vector store backend for RAG: "memory" (default, $0) or "chroma" ---
VECTOR_BACKEND=memory

# --- Advanced RAG ---
EMBEDDING_BACKEND=hashing   # hashing ($0, offline) | gemini (neural, needs key)
RETRIEVAL_MODE=hybrid       # hybrid (BM25+dense RRF) | dense | bm25
RERANKER=lexical            # lexical (deterministic) | llm (Gemini) | none

# --- Ingest real IBM AMLworld dataset as extra cases (adds AML-#### cases) ---
INCLUDE_AMLWORLD=0

# --- Observability (optional): Langfuse. Leave blank to disable (tracing no-ops). ---
# Free cloud keys: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Rate limiting (per client key/IP, sliding window) ---
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
